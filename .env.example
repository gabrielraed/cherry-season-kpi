# Copiá este archivo a .env y completá los valores antes de correr la app.

DATABASE_URL="file:./dev.db"

# Generá uno propio, por ejemplo con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="reemplazar-por-un-secreto-random"

# Credenciales del usuario admin que crea el seed (prisma/seed.ts).
SEED_ADMIN_EMAIL="admin@cafeteria.com"
SEED_ADMIN_PASSWORD="cambiar-esta-contrasena"
